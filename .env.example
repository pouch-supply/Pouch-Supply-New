# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB Atlas Connection URI
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/pouchsupply?retryWrites=true&w=majority
MONGODB_URI=

# Worldpay Payment Gateway Credentials (for live API requests)
WORLDPAY_MERCHANT_ID=
WORLDPAY_API_USERNAME=
WORLDPAY_API_PASSWORD=
WORLDPAY_ENTITY_ID=
WORLDPAY_CHECKOUT_ID=
WORLDPAY_WEBHOOK_SECRET=

# Email Outbox Server Credentials (Nodemailer)
# Host is smtp.ionos.co.uk or similar for pouch-supply.com mail server
EMAIL_HOST=smtp.ionos.co.uk
EMAIL_PORT=587
EMAIL_USER=Support@pouch-supply.com
EMAIL_PASS="January14!2019"
EMAIL_FROM="Support <Support@pouch-supply.com>"

# AgeChecked App Credentials (for compliance sweeps & automated age gating checks)
AGECHECKED_PUBLIC_KEY=
AGECHECKED_SECRET_KEY=

# Cloudinary Media CDN Credentials (for safe, high-speed image & video streaming)
# Register for free at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

