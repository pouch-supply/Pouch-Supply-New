# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB Atlas Connection URI
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/pouchsupply?retryWrites=true&w=majority
MONGODB_URI=

# Worldpay Payment Gateway Credentials
# For Worldpay Business Gateway Hosted Payment Page redirection:
WORLDPAY_INSTALLATION_ID=
# For Worldpay Access / Oppwa API:
WORLDPAY_API_USERNAME=
WORLDPAY_API_PASSWORD=
WORLDPAY_ENTITY_ID=
WORLDPAY_TEST_MODE=0 # 100 for Test Mode, 0 for Live Mode
WORLDPAY_WEBHOOK_SECRET=

# Email Outbox Server Credentials (SMTP / Gmail App Password)
# For Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=465, EMAIL_USER=scottkivlinpouch@gmail.com, EMAIL_PASS=<16-character Gmail App Password>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=scottkivlinpouch@gmail.com
EMAIL_PASS=
EMAIL_FROM=scottkivlinpouch@gmail.com

# AgeChecked Official API Credentials (UK Tobacco / Nicotine PAS 1296)
AGECHECKED_PUBLIC_KEY=
AGECHECKED_SECRET_KEY=
AGECHECKED_SERVICE_ID=
AGECHECKED_ENVIRONMENT=production # production or sandbox

# Cloudinary Media CDN Credentials (for safe, high-speed image & video streaming)
# Register for free at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

